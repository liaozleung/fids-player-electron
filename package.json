{
  "name": "fids-player-electron",
  "version": "0.1.0",
  "description": "FIDS 航显播放器 (Electron 版)",
  "author": "hzwl",
  "main": "./out/main/index.js",

  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",

    "build:win": "npm run build && electron-builder --win --x64 --publish never",
    "build:linux": "npm run build && electron-builder --linux AppImage --x64",
    "build:linux:deb": "npm run build && electron-builder --linux deb --x64",
    "build:mac": "npm run build && electron-builder --mac"
  },

  "dependencies": {
    "mqtt": "^5.10.0",
    "systeminformation": "^5.23.0"
  },

  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
